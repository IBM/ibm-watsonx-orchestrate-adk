            "nodes": {
                "CodeBlock 1": {
                    "spec": {
                        "fn": "self.output.brands = [\n    \"Acura\",\n    \"Alfa Romeo\",\n    \"Aston Martin\",\n    \"Audi\",\n    \"Bentley\",\n    \"BMW\",\n    \"Bugatti\",\n    \"Buick\",\n    \"Cadillac\",\n    \"Chevrolet\",\n    \"Chrysler\",\n    \"Citroën\",\n    \"Dacia\",\n    \"Dodge\",\n    \"Ferrari\",\n    \"Fiat\",\n    \"Ford\",\n    \"Genesis\",\n    \"GMC\",\n    \"Honda\",\n    \"Hyundai\",\n    \"Infiniti\",\n    \"Jaguar\",\n    \"Jeep\",\n    \"Kia\",\n    \"Koenigsegg\",\n    \"Lamborghini\",\n    \"Land Rover\",\n    \"Lexus\",\n    \"Lincoln\",\n    \"Lotus\",\n    \"Maserati\",\n    \"Mazda\",\n    \"McLaren\",\n    \"Mercedes-Benz\",\n    \"Mini\",\n    \"Mitsubishi\",\n    \"Nissan\",\n    \"Pagani\",\n    \"Peugeot\",\n    \"Polestar\",\n    \"Porsche\",\n    \"Ram\",\n    \"Renault\",\n    \"Rolls-Royce\",\n    \"Saab\",\n    \"Subaru\",\n    \"Suzuki\",\n    \"Tesla\",\n    \"Toyota\",\n    \"Volkswagen\",\n    \"Volvo\"\n  ]",
                        "kind": "script",
                        "name": "CodeBlock 1",
                        "position": {
                            "x": 20,
                            "y": 110
                        },
                        "display_name": "Car Brands",
                        "output_schema": {
                            "type": "object",
                            "properties": {
                                "brands": {
                                    "type": "array",
                                    "items": {
                                        "type": "string"
                                    },
                                    "description": "list of brands\n"
                                }
                            }
                        }
                    }
                },
                "CodeBlock 2": {
                    "spec": {
                        "fn": "# Read registration date from previous node (MM/DD/YYYY format)\nreg_date_str = flow[\"Get car details\"][\"Registration Date\"].output.value\n\n# Parse the date\nreg_date = datetime.datetime.strptime(reg_date_str, \"%Y-%m-%d\").date()\n    \n# Calculate integer age in years\ntoday = datetime.date.today()\nage_years = today.year - reg_date.year - (\n    (today.month, today.day) < (reg_date.month, reg_date.day)\n)\n    \n# Pass the age down the flow\nself.output.age = age_years\n\nself.output.quote = 4236.90",
                        "kind": "script",
                        "name": "CodeBlock 2",
                        "position": {
                            "x": 20,
                            "y": 986
                        },
                        "display_name": "Calculate quote",
                        "output_schema": {
                            "type": "object",
                            "properties": {
                                "age": {
                                    "type": "integer",
                                    "description": "car age\n"
                                },
                                "quote": {
                                    "type": "number",
                                    "description": "car price\n"
                                }
                            }
                        }
                    }
                },
