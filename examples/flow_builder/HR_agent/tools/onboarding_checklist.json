        "CodeBlock 1": {
            "spec": {
                "fn": "flow.private.getcontextvariable = system.context.get_variable(\"Role\")\nflow.private.emailID = system.context.get_variable(\"wxo_email_id\")\n\nemail = \"Aayush@ibm.com\"\nif flow.private.emailID == email:\n    flow.private.role=\"Product Manager\"\n\nusername = email.split(\"@\")[0]\nname = username.split(\".\")[0]\nself.output.name = name\n\n\nrole = flow.private.role\n\nif role == \"Product Manager\":\n    checklist=[\n    \"Meet your engineering and design teams\",\n    \"Understand product vision and roadmap\",\n    \"Review current features and backlog\",\n    \"Get access to product tools (Jira, Slack, dashboards)\",\n    \"Study key metrics (KPIs, user analytics)\",\n    \"Align with stakeholders on priorities\",\n    \"Shadow customer calls or demos\"\n    ]\n\nelif role == \"Developer\":\n    checklist=[\n        \"Set up development environment\",\n    \"Get access to repositories (GitHub/GitLab)\",\n    \"Clone and run the project locally\",\n    \"Review codebase structure and architecture\",\n    \"Understand deployment process\",\n    \"Fix a small bug or pick a starter task\",\n    \"Attend team stand-ups and tech syncs\"\n    ]\n\nself.output.checklist = checklist",
                "kind": "script",
                "name": "CodeBlock 1",
