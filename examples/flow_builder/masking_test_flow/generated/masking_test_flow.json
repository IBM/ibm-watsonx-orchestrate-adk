        },
        "fn": "\n# Create list of email records with API tokens\nself.output.emails = [\n    {\n        \"recipient\": flow.input.username + \"@example.com\",\n        \"api_token\": f\"TOKEN-{flow.private.credentials.auth_token[:16]}\"\n    }\n]\n"
