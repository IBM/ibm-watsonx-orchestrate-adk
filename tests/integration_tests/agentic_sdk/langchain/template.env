# WxO LangChain Integration Test Configuration
# Copy this file to .env and fill in your credentials

## Local WxO Instance (Developer Edition)

# Note: LOCAL_WXO_API_KEY is NOT required - local uses default credentials
# Make sure to configure LLM provider API keys in the .env file used when starting the local ADK server

LOCAL_WXO_BASE_URL=http://localhost:4321

# Chat Models for ChatWxO tests
LOCAL_CHAT_MODEL_1=groq/openai/gpt-oss-120b
LOCAL_CHAT_MODEL_2=watsonx/meta-llama/llama-3-2-90b-vision-instruct

# Embedding Model for WxOEmbeddings tests
LOCAL_EMBEDDING_MODEL=openai/text-embedding-3-small


## SaaS WxO Instance

SAAS_WXO_BASE_URL=https://your-instance.cloud.ibm.com

SAAS_WXO_API_KEY=your-saas-api-key-here
SAAS_AUTH_TYPE=mcsp
SAAS_IAM_URL=https://your-iam-instance.ibm.com

# Chat Models for ChatWxO tests
SAAS_CHAT_MODEL_1=watsonx/meta-llama/llama-3-2-90b-vision-instruct
SAAS_CHAT_MODEL_2=groq/openai/gpt-oss-120b

# Embedding Model for WxOEmbeddings tests
SAAS_EMBEDDING_MODEL=openai/text-embedding-3-small
